# GeoTrade Environment Configuration
# Copy this file to .env and fill in your API keys
# DO NOT commit .env files with real API keys to git

# ========================
# CORE APP CONFIG
# ========================
ENV=development
PORT=8000
LOG_LEVEL=INFO

# ========================
# DATABASE
# ========================
DATABASE_URL=postgresql+asyncpg://geotrade:geotrade_secret@localhost:5432/geotrade
DATABASE_SYNC_URL=postgresql+psycopg2://geotrade:geotrade_secret@localhost:5432/geotrade

# ========================
# REDIS (OPTIONAL)
# ========================
REDIS_URL=redis://localhost:6379/0

# ========================
# COINGECKO (CRYPTO - FREE, NO KEY REQUIRED)
# ========================
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ========================
# ALPACA (STOCKS + ETFs)
# Get keys at: https://alpaca.markets/
# ========================
ALPACA_API_KEY=CKDUNH5YGG2LYY27IV2HJBU5EV
ALPACA_SECRET_KEY=DYpjrX1J5b9EECPPUgY8rdRok9KmiqRg2w6zNygddq9c
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ========================
# TWELVE DATA (FOREX + COMMODITIES)
